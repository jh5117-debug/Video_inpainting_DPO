#!/bin/bash
#SBATCH --job-name=DE_Stage1
#SBATCH --partition=pgpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:8
#SBATCH --cpus-per-task=16
#SBATCH --mem=200G
#SBATCH --time=48:00:00
#SBATCH --output=logs/train-stage1-%j.out

PROJECT_ROOT="${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

NUM_GPUS=${NUM_GPUS:-8}
DATA_DIR=${DATA_DIR:-${PROJECT_ROOT}/data}
WEIGHTS_DIR=${WEIGHTS_DIR:-${PROJECT_ROOT}/weights}
BATCH_SIZE=${BATCH_SIZE:-1}
GRAD_ACCUM=${GRAD_ACCUM:-4}
LR=${LR:-5e-6}
LR_SCHEDULER=${LR_SCHEDULER:-constant}
LR_WARMUP=${LR_WARMUP:-500}
MAX_STEPS=${MAX_STEPS:-26000}
CKPT_STEPS=${CKPT_STEPS:-2000}
CKPT_LIMIT=${CKPT_LIMIT:-3}
VAL_STEPS=${VAL_STEPS:-2000}
NFRAMES=${NFRAMES:-10}
SEED=${SEED:-42}
MIXED_PRECISION=${MIXED_PRECISION:-fp16}
WANDB_PROJECT=${WANDB_PROJECT:-DPO_Diffueraser}
WANDB_ENTITY=${WANDB_ENTITY:-jh5117-columbia-university}
EXPERIMENTS_DIR=${EXPERIMENTS_DIR:-${PROJECT_ROOT}/experiments}
RUN_NAME=${RUN_NAME:-stage1}
RUN_VERSION=${RUN_VERSION:-}

RUN_VERSION_ARG=()
if [[ -n "${RUN_VERSION}" ]]; then
  RUN_VERSION_ARG=(--run_version "${RUN_VERSION}")
fi

source ~/.bashrc
conda activate diffueraser
cd "$PROJECT_ROOT"

python training/sft/scripts/run_stage1.py \
  --num_gpus ${NUM_GPUS} \
  --data_dir ${DATA_DIR} \
  --weights_dir ${WEIGHTS_DIR} \
  --experiments_dir ${EXPERIMENTS_DIR} \
  --run_name ${RUN_NAME} \
  --batch_size ${BATCH_SIZE} \
  --gradient_accumulation_steps ${GRAD_ACCUM} \
  --learning_rate ${LR} \
  --lr_scheduler ${LR_SCHEDULER} \
  --lr_warmup_steps ${LR_WARMUP} \
  --max_train_steps ${MAX_STEPS} \
  --checkpointing_steps ${CKPT_STEPS} \
  --checkpoints_total_limit ${CKPT_LIMIT} \
  --validation_steps ${VAL_STEPS} \
  --nframes ${NFRAMES} \
  --seed ${SEED} \
  --mixed_precision ${MIXED_PRECISION} \
  --wandb_project ${WANDB_PROJECT} \
  --wandb_entity ${WANDB_ENTITY} \
  "${RUN_VERSION_ARG[@]}"
