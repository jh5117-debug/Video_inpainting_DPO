#!/bin/bash
#SBATCH --job-name=DPO_S1
#SBATCH --partition=pgpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:8
#SBATCH --cpus-per-task=16
#SBATCH --mem=200G
#SBATCH --time=48:00:00
#SBATCH --output=logs/dpo-stage1-%j.out

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ====================== Editable SC Defaults ======================
# Repo checkout path: ${PROJECT_DEV}/${PROJECT_NAME}
# Data/root assets path: ${PROJECT_DATA}/${DATA_NAME}
PROJECT_NAME="Video_inpainting_DPO"
DATA_NAME="Video_inpainting_DPO"

MIXED_PRECISION="${MIXED_PRECISION:-bf16}"
VAE_DTYPE="${VAE_DTYPE:-auto}"
VAL_NUM_INFERENCE_STEPS="${VAL_NUM_INFERENCE_STEPS:-6}"
VAL_MASK_DILATION_ITER="${VAL_MASK_DILATION_ITER:-0}"
NUM_GPUS="${NUM_GPUS:-8}"
BATCH_SIZE="${BATCH_SIZE:-1}"
GRAD_ACCUM="${GRAD_ACCUM:-1}"
NUM_WORKERS="${NUM_WORKERS:-0}"
DPO_DATASET_TYPE="${DPO_DATASET_TYPE:-diffueraser_inpainting}"
MAX_EPOCHS="${MAX_EPOCHS:-}"
if [[ -z "${MAX_STEPS+x}" ]]; then
  if [[ "${DPO_DATASET_TYPE}" == "videodpo_fullmask" ]]; then
    MAX_STEPS=""
    MAX_EPOCHS="${MAX_EPOCHS:-10}"
  else
    MAX_STEPS="20000"
  fi
else
  MAX_STEPS="${MAX_STEPS}"
fi
CKPT_STEPS="${CKPT_STEPS:-2000}"
VAL_STEPS="${VAL_STEPS:-2000}"
LOGGING_STEPS="${LOGGING_STEPS:-300}"
DPO_DIAGNOSTICS="${DPO_DIAGNOSTICS:-1}"
CKPT_LIMIT="${CKPT_LIMIT:-1}"
RESOLUTION="${RESOLUTION:-512}"
TRAIN_HEIGHT="${TRAIN_HEIGHT:-${RESOLUTION}}"
TRAIN_WIDTH="${TRAIN_WIDTH:-${RESOLUTION}}"

RUN_NAME="${RUN_NAME:-sc-dpo-stage1-newdata-bf16-raw6-nodil}"
CHUNK_ALIGNED="${CHUNK_ALIGNED:-1}"
SPLIT_POS_NEG_FORWARD="${SPLIT_POS_NEG_FORWARD:-1}"
USE_8BIT_ADAM="${USE_8BIT_ADAM:-0}"
GRADIENT_CHECKPOINTING="${GRADIENT_CHECKPOINTING:-1}"
XFORMERS="${XFORMERS:-0}"
DEBUG_FIRST_BATCH_STAGES="${DEBUG_FIRST_BATCH_STAGES:-0}"
BETA_DPO="${BETA_DPO:-500.0}"
SFT_REG_WEIGHT="${SFT_REG_WEIGHT:-0.0}"
DPO_LOSE_GAP_WEIGHT="${DPO_LOSE_GAP_WEIGHT:-1.0}"
VIDEODPO_FRAME_STRIDE="${VIDEODPO_FRAME_STRIDE:-1}"
VIDEODPO_CLIP_LENGTH="${VIDEODPO_CLIP_LENGTH:-1.0}"
VIDEODPO_FULL_MASK_VALUE="${VIDEODPO_FULL_MASK_VALUE:-0.0}"
WANDB_ENTITY="${WANDB_ENTITY:-jh5117-columbia-university}"
WANDB_PROJECT="${WANDB_PROJECT:-DPO_Diffueraser}"
# ================================================================

if [[ -z "${PROJECT_ROOT:-}" ]]; then
  if [[ -n "${PROJECT_DEV:-}" ]]; then
    export PROJECT_ROOT="${PROJECT_DEV}/${PROJECT_NAME}"
  elif [[ -n "${PROJECT_HOME:-}" ]]; then
    export PROJECT_ROOT="${PROJECT_HOME}/dev/${PROJECT_NAME}"
  else
    export PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
  fi
fi
export PROJECT_HOME="${PROJECT_HOME:-/sc-projects/sc-proj-cc09-repair/hongyou}"
export PROJECT_DEV="${PROJECT_DEV:-${PROJECT_HOME}/dev}"
export PROJECT_DATA="${PROJECT_DATA:-${PROJECT_DEV}/data}"
export DATA="${DATA:-${PROJECT_DATA}/${DATA_NAME}}"
export DATA_NAME
export WEIGHTS_DIR="${WEIGHTS_DIR:-${DATA}/weights}"
export DPO_DATA_ROOT="${DPO_DATA_ROOT:-${DATA}/DPO_Finetune_data}"
export DPO_DATASET_TYPE
export VAL_DATA_DIR="${VAL_DATA_DIR:-${DATA}/davis_432_240}"
export EXPERIMENTS_DIR="${EXPERIMENTS_DIR:-${DATA}/experiments}"
REPORT_TO="${REPORT_TO:-wandb}"
export WANDB_PROJECT WANDB_ENTITY
export MIXED_PRECISION VAE_DTYPE VAL_NUM_INFERENCE_STEPS VAL_MASK_DILATION_ITER
export NUM_GPUS BATCH_SIZE GRAD_ACCUM NUM_WORKERS MAX_STEPS MAX_EPOCHS CKPT_STEPS VAL_STEPS CKPT_LIMIT
export LOGGING_STEPS DPO_DIAGNOSTICS
export RESOLUTION TRAIN_HEIGHT TRAIN_WIDTH
export RUN_NAME CHUNK_ALIGNED SPLIT_POS_NEG_FORWARD GRADIENT_CHECKPOINTING XFORMERS DEBUG_FIRST_BATCH_STAGES
export USE_8BIT_ADAM
export BETA_DPO SFT_REG_WEIGHT DPO_LOSE_GAP_WEIGHT
export DPO_DATASET_TYPE VIDEODPO_FRAME_STRIDE VIDEODPO_CLIP_LENGTH VIDEODPO_FULL_MASK_VALUE
export REPORT_TO
exec bash "${PROJECT_ROOT}/training/dpo/scripts/03_dpo_stage1.sbatch" "$@"
