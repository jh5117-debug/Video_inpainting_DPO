# Copy to a private shell/env file on the target machine and edit paths.
# Do not commit real private paths or secrets.

export VIDEO_DPO_DATA_ROOT="${VIDEO_DPO_DATA_ROOT:-/path/to/videodpo/data}"
export VIDEO_DPO_OFFICIAL_ROOT="${VIDEO_DPO_OFFICIAL_ROOT:-/path/to/official/VideoDPO}"
export VIDEO_DPO_TRAIN_DATA_YAML="${VIDEO_DPO_TRAIN_DATA_YAML:-/path/to/videodpo/configs/vc2_dpo/vidpro/train_data.pai.yaml}"
export VIDEO_DPO_PAIR_MANIFEST="${VIDEO_DPO_PAIR_MANIFEST:-}"
export VIDEO_DPO_WINNER_ROOT="${VIDEO_DPO_WINNER_ROOT:-}"
export VIDEO_DPO_REJECTED_ROOT="${VIDEO_DPO_REJECTED_ROOT:-}"
export VIDEO_DPO_PROMPT_FILE="${VIDEO_DPO_PROMPT_FILE:-}"
export YOUTUBE_VOS_ROOT="${YOUTUBE_VOS_ROOT:-/path/to/youtubevos}"
export YOUTUBE_VOS_FRAMES_ROOT="${YOUTUBE_VOS_FRAMES_ROOT:-/path/to/youtubevos/JPEGImages}"
export YOUTUBE_VOS_MASKS_ROOT="${YOUTUBE_VOS_MASKS_ROOT:-/path/to/youtubevos/Annotations}"
export GENERATED_LOSER_ROOT="${GENERATED_LOSER_ROOT:-/path/to/generated_losers}"

export DIFFUERASER_WEIGHT_ROOT="${DIFFUERASER_WEIGHT_ROOT:-/path/to/weights/diffueraser}"
export PROPAINTER_WEIGHT_ROOT="${PROPAINTER_WEIGHT_ROOT:-/path/to/weights/propainter}"
export COCOCO_WEIGHT_ROOT="${COCOCO_WEIGHT_ROOT:-/path/to/weights/cococo}"
export MINIMAX_REMOVER_WEIGHT_ROOT="${MINIMAX_REMOVER_WEIGHT_ROOT:-/path/to/weights/minimax_remover}"
export OFFICIAL_VIDEODPO_ROOT="${OFFICIAL_VIDEODPO_ROOT:-/path/to/official/VideoDPO}"
export OFFICIAL_VIDEODPO_WEIGHT_ROOT="${OFFICIAL_VIDEODPO_WEIGHT_ROOT:-/path/to/official/VideoDPO/checkpoints}"
export VC2_WEIGHT_ROOT="${VC2_WEIGHT_ROOT:-/path/to/weights/vc2}"

export EXP_OUTPUT_ROOT="${EXP_OUTPUT_ROOT:-/path/to/experiment_outputs}"
export LINGBOT_PROCESS_NAME="${LINGBOT_PROCESS_NAME:-lingbot-phy}"
